<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="voA"
            type="com.intellizon.biofeedbacktest.vo.ChannelVO" />

        <variable
            name="voB"
            type="com.intellizon.biofeedbacktest.vo.ChannelVO" />

        <variable
            name="voC"
            type="com.intellizon.biofeedbacktest.vo.ChannelVO" />

        <variable
            name="voD"
            type="com.intellizon.biofeedbacktest.vo.ChannelVO" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/vGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/hGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.5" />


        <!-- 通道A（左上） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/expCardA"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/hGuide"
            app:layout_constraintEnd_toStartOf="@id/vGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 标题 + 勾选框（同一行） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTitleA"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="通道A(低频)"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbSelectA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <include
                    android:id="@+id/expContentA"
                    layout="@layout/view_channel_a_low_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:channelVo="@{voA}" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 通道B（右上） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/expCardB"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/hGuide"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/vGuide"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 标题 + 勾选框（同一行） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTitleB"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="通道B(低频)"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbSelectB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <include
                    android:id="@+id/expContentB"
                    layout="@layout/view_channel_a_low_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:channelVo="@{voB}" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 通道C（左下） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/expCardC"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/vGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/hGuide">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 标题 + 勾选框（同一行） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTitleC"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="通道C(低频)"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbSelectC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <include
                    android:id="@+id/expContentC"
                    layout="@layout/view_channel_a_low_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:channelVo="@{voC}" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 通道D（右下） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/expCardD"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/vGuide"
            app:layout_constraintTop_toBottomOf="@id/hGuide">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 标题 + 勾选框（同一行） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTitleD"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="通道D(低频)"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbSelectD"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <include
                    android:id="@+id/expContentD"
                    layout="@layout/view_channel_a_low_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:channelVo="@{voD}" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 中间圆形按钮 -->
        <ImageButton
            android:id="@+id/btnCenterInfo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/black_cry_head"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:elevation="12dp"
            android:contentDescription="@null"
            app:layout_constraintStart_toStartOf="@id/vGuide"
            app:layout_constraintEnd_toEndOf="@id/vGuide"
            app:layout_constraintTop_toTopOf="@id/hGuide"
            app:layout_constraintBottom_toBottomOf="@id/hGuide" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>